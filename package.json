{
  "name": "custom-bite-suite",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "node scripts/run-android.js",
    "android:clean-native": "node scripts/clean-android-native.js",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:apk": "cd android && gradlew assembleDebug",
    "build:apk:release": "cd android && gradlew assembleRelease",
    "check:transport-security": "node scripts/check-transport-security.js",
    "lint": "eslint App.tsx src --ext .ts,.tsx",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "validate:repo-layout": "node scripts/validate-repository-layout.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-crypto": "~15.0.8",
    "expo-image-picker": "^55.0.18",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-secure-store": "^55.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^10.2.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
